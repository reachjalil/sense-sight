---
import "../styles/console.css";

interface Props {
  description?: string;
  title?: string;
}

const {
  description = "The SenseSight console streams progressive Gaussian-splat reconstruction in real time — watch the splat rebuild as the robot's sensor stream arrives.",
  title = "SenseSight Console — live world generation",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <noscript>
      <p style="padding:24px;color:#9caeb6;font-family:system-ui">
        The SenseSight console renders an interactive 3D viewer and requires
        JavaScript.
      </p>
    </noscript>
  </body>
</html>
