---
const links = [
  { href: "/world", label: "World" },
  { href: "/loop", label: "Loop" },
  { href: "/stack", label: "Stack" },
  { href: "/open-source", label: "Open Source" },
  { href: "/console", label: "Live Console" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActivePath(href: string) {
  return currentPath === href;
}
---

<header class="ss-nav">
  <nav class="ss-container ss-nav__inner" aria-label="Primary">
    <a class="ss-wordmark" href="/" aria-label="SenseSight home">
      <img
        class="ss-mark"
        src="/brand/sensesight-mark.svg"
        alt=""
        width="32"
        height="32"
        decoding="async"
      />
      <span>SenseSight</span>
    </a>

    <ul class="ss-nav__links">
      {
        links.map((link) => {
          const isActive = isActivePath(link.href);

          return (
          <li>
            <a
              class:list={{ "is-active": isActive }}
              href={link.href}
              aria-current={isActive ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
          );
        })
      }
    </ul>

    <a class="ss-btn ss-btn--small" href="https://github.com/reachjalil/sense-sight">
      GitHub
    </a>
  </nav>
</header>
