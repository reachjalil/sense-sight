---
const telemetry = [
  { label: "RGB", value: "60 fps" },
  { label: "Depth", value: "aligned" },
  { label: "Pose", value: "tracking" },
  { label: "World", value: "streaming" },
];

const cameraViews = [
  { id: "orbit", label: "Orbit", key: "1" },
  { id: "top", label: "Top", key: "2" },
  { id: "robot", label: "Robot", key: "3" },
  { id: "review", label: "Review", key: "4" },
];
---

<figure
  class="ss-world-preview"
  data-world-preview
  aria-label="Realtime robot world generation preview"
>
  <div class="ss-world-preview__viewport">
    <div class="ss-world-preview__stage">
      <canvas
        class="ss-world-preview__canvas"
        data-world-canvas
        tabindex="0"
        role="img"
        aria-label="Interactive 3D preview of a robot-generated point cloud world model."
      ></canvas>
      <div class="ss-world-preview__hud ss-world-preview__hud--top">
        <span><i class="ss-dot"></i> Live capture</span>
        <span>Clark Center Atrium</span>
      </div>
      <div class="ss-world-preview__hud ss-world-preview__hud--bottom">
        {
          telemetry.map((item) => (
            <span>
              <strong>{item.label}</strong>
              {item.value}
            </span>
          ))
        }
      </div>
      <p class="ss-world-preview__status" data-world-status aria-live="polite">
        Orbit camera
      </p>
    </div>
    <div class="ss-world-preview__controls" aria-label="3D world controls">
      <div class="ss-world-preview__view-tabs" role="group" aria-label="Camera views">
        {
          cameraViews.map((view) => (
            <button
              type="button"
              class="ss-world-preview__view-button"
              data-camera-view={view.id}
              aria-pressed={view.id === "orbit" ? "true" : "false"}
              aria-keyshortcuts={view.key}
              title={`Shortcut ${view.key}`}
            >
              {view.label}
            </button>
          ))
        }
      </div>
      <div class="ss-world-preview__actions">
        <button
          type="button"
          class="ss-world-preview__icon-button"
          data-world-fit
          aria-label="Fit world"
          aria-keyshortcuts="F"
          title="Fit world"
        >
          Fit
        </button>
        <button
          type="button"
          class="ss-world-preview__icon-button"
          data-world-auto
          aria-label="Toggle automatic orbit"
          aria-pressed="true"
          title="Auto orbit"
        >
          Auto
        </button>
      </div>
    </div>
  </div>
</figure>

<script>
  import {
    BoxGeometry,
    BufferAttribute,
    BufferGeometry,
    Color,
    CylinderGeometry,
    DirectionalLight,
    DoubleSide,
    FogExp2,
    GridHelper,
    Group,
    HemisphereLight,
    Line,
    LineBasicMaterial,
    MathUtils,
    Mesh,
    MeshBasicMaterial,
    MeshStandardMaterial,
    PerspectiveCamera,
    PlaneGeometry,
    Points,
    PointsMaterial,
    Raycaster,
    RingGeometry,
    Scene,
    SphereGeometry,
    Spherical,
    SRGBColorSpace,
    Vector2,
    Vector3,
    WebGLRenderer,
  } from "three";
  import type { Material, Object3D } from "three";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";

  type CameraPreset = {
    id: string;
    label: string;
    fov: number;
    position: [number, number, number];
    target: [number, number, number];
  };

  const cameraPresets: CameraPreset[] = [
    {
      id: "orbit",
      label: "Orbit camera",
      fov: 47,
      position: [6.7, 5.2, 8.2],
      target: [0.15, 1.15, -0.25],
    },
    {
      id: "top",
      label: "Top camera",
      fov: 42,
      position: [0.1, 12.6, 0.1],
      target: [0, 0.05, 0],
    },
    {
      id: "robot",
      label: "Robot camera",
      fov: 54,
      position: [-2.4, 1.55, 6.6],
      target: [0.25, 1.08, 0.4],
    },
    {
      id: "review",
      label: "Review camera",
      fov: 45,
      position: [-7.8, 3.2, 3.4],
      target: [0.2, 1.0, -1.6],
    },
  ];

  const roots = document.querySelectorAll<HTMLElement>("[data-world-preview]");

  for (const root of roots) {
    initializeWorldPreview(root);
  }

  function initializeWorldPreview(root: HTMLElement) {
    const stage = root.querySelector<HTMLElement>(".ss-world-preview__stage");
    const canvas = root.querySelector<HTMLCanvasElement>("[data-world-canvas]");
    const status = root.querySelector<HTMLElement>("[data-world-status]");

    if (!stage || !canvas || !status) {
      return;
    }

    const stageElement = stage;
    const canvasElement = canvas;
    const statusElement = status;

    const renderer = new WebGLRenderer({
      antialias: true,
      canvas: canvasElement,
      powerPreference: "high-performance",
    });
    renderer.outputColorSpace = SRGBColorSpace;
    renderer.setClearColor(0x05070a, 1);

    const scene = new Scene();
    scene.fog = new FogExp2(0x05070a, 0.035);

    const camera = new PerspectiveCamera(47, 1, 0.1, 80);
    const controls = new OrbitControls(camera, canvasElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.08;
    controls.enablePan = true;
    controls.enableZoom = true;
    controls.maxDistance = 17;
    controls.maxPolarAngle = Math.PI * 0.49;
    controls.minDistance = 2.6;
    controls.minPolarAngle = 0.12;
    controls.screenSpacePanning = false;
    controls.target.set(0.15, 1.15, -0.25);

    const world = createWorldScene();
    scene.add(world.group);

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const raycaster = new Raycaster();
    const pointer = new Vector2();
    const reusableVector = new Vector3();
    const reusableForward = new Vector3();
    const reusableRight = new Vector3();
    const reusableSpherical = new Spherical();
    const startedAt = performance.now();
    const abortController = new AbortController();
    const { signal } = abortController;
    const viewButtons = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-camera-view]")
    );
    const autoButton = root.querySelector<HTMLButtonElement>("[data-world-auto]");
    const fitButton = root.querySelector<HTMLButtonElement>("[data-world-fit]");
    let frameId = 0;
    let activeAnchor: Object3D | null = null;
    let currentViewIndex = 0;
    let autoOrbitRequested = !reducedMotion.matches;
    let cameraTween: {
      startedAt: number;
      duration: number;
      fromFov: number;
      fromPosition: Vector3;
      fromTarget: Vector3;
      toFov: number;
      toPosition: Vector3;
      toTarget: Vector3;
    } | null = null;

    applyPreset("orbit", false);
    updateAutoOrbit(autoOrbitRequested);

    const resizeObserver = new ResizeObserver(() => resizeRenderer());
    resizeObserver.observe(stageElement);
    resizeRenderer();

    for (const button of viewButtons) {
      button.addEventListener(
        "click",
        () => {
          const view = button.dataset.cameraView;

          if (view) {
            applyPreset(view, true);
          }
        },
        { signal }
      );
    }

    autoButton?.addEventListener(
      "click",
      () => updateAutoOrbit(!autoOrbitRequested),
      { signal }
    );

    fitButton?.addEventListener(
      "click",
      () => applyPreset("orbit", true),
      { signal }
    );

    canvasElement.addEventListener(
      "pointerdown",
      () => {
        canvasElement.focus({ preventScroll: true });
        cameraTween = null;
        updateAutoOrbit(false);
      },
      { signal }
    );

    canvasElement.addEventListener("pointermove", handlePointerMove, { signal });
    canvasElement.addEventListener(
      "pointerleave",
      () => {
        activeAnchor = null;
        canvasElement.style.cursor = "grab";
        setStatus(cameraPresets[currentViewIndex]?.label ?? "Orbit camera");
      },
      { signal }
    );

    canvasElement.addEventListener(
      "click",
      () => {
        if (activeAnchor) {
          inspectAnchor(activeAnchor);
        }
      },
      { signal }
    );

    root.addEventListener("keydown", handleKeyboard, { signal });

    reducedMotion.addEventListener(
      "change",
      () => updateAutoOrbit(autoOrbitRequested),
      { signal }
    );

    window.addEventListener("pagehide", dispose, { once: true, signal });
    document.addEventListener("astro:before-swap", dispose, {
      once: true,
      signal,
    });

    frameId = window.requestAnimationFrame(render);

    function resizeRenderer() {
      const { height, width } = stageElement.getBoundingClientRect();
      const nextWidth = Math.max(1, Math.floor(width));
      const nextHeight = Math.max(1, Math.floor(height));
      const pixelRatio = Math.min(window.devicePixelRatio || 1, 2);

      renderer.setPixelRatio(pixelRatio);
      renderer.setSize(nextWidth, nextHeight, false);
      camera.aspect = nextWidth / nextHeight;
      camera.updateProjectionMatrix();
    }

    function handlePointerMove(event: PointerEvent) {
      const rect = canvasElement.getBoundingClientRect();
      pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
      raycaster.setFromCamera(pointer, camera);

      const [hit] = raycaster.intersectObjects(world.interactiveAnchors, false);
      activeAnchor = hit?.object ?? null;
      canvasElement.style.cursor = activeAnchor ? "pointer" : "grab";

      if (activeAnchor?.userData.label) {
        setStatus(String(activeAnchor.userData.label));
      }
    }

    function handleKeyboard(event: KeyboardEvent) {
      if (event.altKey || event.ctrlKey || event.metaKey) {
        return;
      }

      const key = event.key.toLowerCase();
      const handled = handleKeyboardCommand(key);

      if (handled) {
        event.preventDefault();
      }
    }

    function handleKeyboardCommand(key: string) {
      const presetIndex = Number(key) - 1;

      if (presetIndex >= 0 && presetIndex < cameraPresets.length) {
        applyPreset(cameraPresets[presetIndex].id, true);
        return true;
      }

      switch (key) {
        case "[":
          cyclePreset(-1);
          return true;
        case "]":
          cyclePreset(1);
          return true;
        case "arrowleft":
          orbitBy(0.12, 0);
          return true;
        case "arrowright":
          orbitBy(-0.12, 0);
          return true;
        case "arrowup":
          orbitBy(0, -0.08);
          return true;
        case "arrowdown":
          orbitBy(0, 0.08);
          return true;
        case "a":
          panGround(-1, 0);
          return true;
        case "d":
          panGround(1, 0);
          return true;
        case "w":
          panGround(0, 1);
          return true;
        case "s":
          panGround(0, -1);
          return true;
        case "-":
        case "_":
          zoomBy(1.12);
          return true;
        case "+":
        case "=":
          zoomBy(0.88);
          return true;
        case "f":
        case "r":
          applyPreset("orbit", true);
          return true;
        default:
          return false;
      }
    }

    function cyclePreset(direction: -1 | 1) {
      const nextIndex =
        (currentViewIndex + direction + cameraPresets.length) %
        cameraPresets.length;
      applyPreset(cameraPresets[nextIndex].id, true);
    }

    function applyPreset(id: string, animate: boolean) {
      const nextIndex = cameraPresets.findIndex((preset) => preset.id === id);
      const preset = cameraPresets[nextIndex] ?? cameraPresets[0];
      currentViewIndex = Math.max(0, nextIndex);
      updateAutoOrbit(false);
      setActiveButton(preset.id);
      setStatus(preset.label);

      const nextPosition = new Vector3(...preset.position);
      const nextTarget = new Vector3(...preset.target);

      if (animate && !reducedMotion.matches) {
        cameraTween = {
          duration: 650,
          fromFov: camera.fov,
          fromPosition: camera.position.clone(),
          fromTarget: controls.target.clone(),
          startedAt: performance.now(),
          toFov: preset.fov,
          toPosition: nextPosition,
          toTarget: nextTarget,
        };
        return;
      }

      cameraTween = null;
      camera.fov = preset.fov;
      camera.position.copy(nextPosition);
      controls.target.copy(nextTarget);
      camera.updateProjectionMatrix();
      controls.update();
    }

    function inspectAnchor(anchor: Object3D) {
      const anchorPosition = anchor.getWorldPosition(new Vector3());
      const currentOffset = camera.position
        .clone()
        .sub(controls.target)
        .setLength(5.2);

      cameraTween = {
        duration: reducedMotion.matches ? 0 : 520,
        fromFov: camera.fov,
        fromPosition: camera.position.clone(),
        fromTarget: controls.target.clone(),
        startedAt: performance.now(),
        toFov: 44,
        toPosition: anchorPosition.clone().add(currentOffset),
        toTarget: anchorPosition,
      };
      updateAutoOrbit(false);
      setStatus(String(anchor.userData.label ?? "Inspect anchor"));
    }

    function updateCameraTween(now: number) {
      if (!cameraTween) {
        return;
      }

      const progress =
        cameraTween.duration === 0
          ? 1
          : clamp((now - cameraTween.startedAt) / cameraTween.duration, 0, 1);
      const eased = easeInOutCubic(progress);

      camera.position.lerpVectors(
        cameraTween.fromPosition,
        cameraTween.toPosition,
        eased
      );
      controls.target.lerpVectors(
        cameraTween.fromTarget,
        cameraTween.toTarget,
        eased
      );
      camera.fov = MathUtils.lerp(
        cameraTween.fromFov,
        cameraTween.toFov,
        eased
      );
      camera.updateProjectionMatrix();

      if (progress >= 1) {
        cameraTween = null;
      }
    }

    function orbitBy(thetaDelta: number, phiDelta: number) {
      cameraTween = null;
      updateAutoOrbit(false);
      reusableVector.copy(camera.position).sub(controls.target);
      reusableSpherical.setFromVector3(reusableVector);
      reusableSpherical.theta += thetaDelta;
      reusableSpherical.phi = clamp(
        reusableSpherical.phi + phiDelta,
        controls.minPolarAngle,
        controls.maxPolarAngle
      );
      reusableSpherical.makeSafe();
      reusableVector.setFromSpherical(reusableSpherical);
      camera.position.copy(controls.target).add(reusableVector);
      controls.update();
      setStatus("Manual orbit");
    }

    function panGround(rightAmount: number, forwardAmount: number) {
      cameraTween = null;
      updateAutoOrbit(false);
      camera.getWorldDirection(reusableForward);
      reusableForward.y = 0;
      reusableForward.normalize();
      reusableRight.setFromMatrixColumn(camera.matrixWorld, 0);
      reusableRight.y = 0;
      reusableRight.normalize();

      const distance = camera.position.distanceTo(controls.target);
      const panScale = Math.max(0.06, distance * 0.035);
      reusableVector
        .copy(reusableRight)
        .multiplyScalar(rightAmount * panScale)
        .addScaledVector(reusableForward, forwardAmount * panScale);

      camera.position.add(reusableVector);
      controls.target.add(reusableVector);
      controls.update();
      setStatus("Manual pan");
    }

    function zoomBy(scale: number) {
      cameraTween = null;
      updateAutoOrbit(false);
      reusableVector.copy(camera.position).sub(controls.target);
      const nextDistance = clamp(
        reusableVector.length() * scale,
        controls.minDistance,
        controls.maxDistance
      );
      reusableVector.setLength(nextDistance);
      camera.position.copy(controls.target).add(reusableVector);
      controls.update();
      setStatus("Manual zoom");
    }

    function setActiveButton(id: string) {
      for (const button of viewButtons) {
        const isActive = button.dataset.cameraView === id;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      }
    }

    function updateAutoOrbit(nextRequested: boolean) {
      autoOrbitRequested = nextRequested;
      controls.autoRotate = autoOrbitRequested && !reducedMotion.matches;
      controls.autoRotateSpeed = 0.28;

      if (autoButton) {
        autoButton.setAttribute("aria-pressed", String(controls.autoRotate));
        autoButton.classList.toggle("is-active", controls.autoRotate);
      }
    }

    function setStatus(nextStatus: string) {
      statusElement.textContent = nextStatus;
    }

    function render(now: number) {
      const elapsed = (now - startedAt) / 1000;

      updateCameraTween(now);
      animateWorld(world, elapsed, reducedMotion.matches);
      controls.update();
      renderer.render(scene, camera);
      frameId = window.requestAnimationFrame(render);
    }

    function dispose() {
      window.cancelAnimationFrame(frameId);
      abortController.abort();
      resizeObserver.disconnect();
      controls.dispose();
      scene.traverse((object: Object3D) => {
        if (hasDisposableGeometry(object)) {
          object.geometry.dispose();
        }

        if (hasDisposableMaterial(object)) {
          const materials = Array.isArray(object.material)
            ? object.material
            : [object.material];

          for (const material of materials) {
            material.dispose();
          }
        }
      });
      renderer.dispose();
    }
  }

  function createWorldScene() {
    const group = new Group();
    const interactiveAnchors: Object3D[] = [];
    const pointCloud = createPointCloud();
    const floor = new Mesh(
      new PlaneGeometry(12, 21),
      new MeshStandardMaterial({
        color: 0x071016,
        metalness: 0.12,
        roughness: 0.82,
      })
    );
    floor.rotation.x = -Math.PI / 2;
    floor.position.y = -0.08;

    const grid = new GridHelper(18, 18, 0x33f0d1, 0x244752);
    grid.position.y = -0.04;
    const gridMaterial = grid.material as LineBasicMaterial;
    gridMaterial.opacity = 0.28;
    gridMaterial.transparent = true;

    const leftWall = createWall(-5.15, Math.PI / 2);
    const rightWall = createWall(5.15, -Math.PI / 2);
    const pathPoints = [
      new Vector3(-2.8, 0.14, 7.1),
      new Vector3(-1.4, 0.14, 3.8),
      new Vector3(0.8, 0.14, 1.1),
      new Vector3(1.2, 0.14, -2.7),
      new Vector3(-1.6, 0.14, -6.5),
    ];
    const path = createPathLine(pathPoints);
    const scan = createScanPlane();
    const robot = createRobot();

    group.add(
      new HemisphereLight(0xbff9ff, 0x101820, 1.28),
      createKeyLight(),
      floor,
      grid,
      leftWall,
      rightWall,
      pointCloud,
      path,
      scan,
      robot
    );

    const anchors = [
      {
        color: 0x33f0d1,
        label: "Depth edge: north entry",
        position: [-2.7, 1.08, 3.4],
      },
      {
        color: 0xffb24d,
        label: "Human review: low confidence glass",
        position: [3.2, 1.34, 0.6],
      },
      {
        color: 0x8fffb3,
        label: "Clear path: service corridor",
        position: [1.1, 0.72, -4.7],
      },
      {
        color: 0x8b9bff,
        label: "Semantic anchor: elevator bank",
        position: [-3.7, 1.82, -2.4],
      },
    ] satisfies Array<{
      color: number;
      label: string;
      position: [number, number, number];
    }>;

    for (const anchor of anchors) {
      const anchorGroup = createAnchor(anchor.color, anchor.label);
      anchorGroup.position.set(...anchor.position);
      group.add(anchorGroup);
      const hitTarget = anchorGroup.children.find(
        (child: Object3D) => child.userData.isHitTarget
      );

      if (hitTarget) {
        interactiveAnchors.push(hitTarget);
      }
    }

    return {
      group,
      interactiveAnchors,
      pathLookTarget: new Vector3(),
      pathPoints,
      robot,
      scan,
    };
  }

  function createPointCloud() {
    const count = 1250;
    const positions = new Float32Array(count * 3);
    const colors = new Float32Array(count * 3);
    const random = createDeterministicRandom(42);
    const machine = new Color(0x33f0d1);
    const field = new Color(0x8fffb3);
    const human = new Color(0xffb24d);
    const violet = new Color(0x8b9bff);
    const mixed = new Color();

    for (let index = 0; index < count; index += 1) {
      const pointType = random();
      const offset = index * 3;
      let x = 0;
      let y = 0;
      let z = 0;

      if (pointType < 0.44) {
        x = randomBetween(random, -4.85, 4.85);
        y = randomBetween(random, -0.02, 0.18);
        z = randomBetween(random, -8.6, 8.4);
        mixed.copy(machine).lerp(field, random() * 0.54);
      } else if (pointType < 0.68) {
        x = random() > 0.5 ? 4.9 : -4.9;
        x += randomBetween(random, -0.16, 0.16);
        y = randomBetween(random, 0.18, 3.35);
        z = randomBetween(random, -8.7, 8.7);
        mixed.copy(violet).lerp(machine, random() * 0.6);
      } else if (pointType < 0.86) {
        const cluster = Math.floor(random() * 5);
        const centerX = [-3.1, -1.4, 2.7, 3.5, 0.6][cluster] ?? 0;
        const centerZ = [4.2, -1.1, 2.7, -4.2, -6.2][cluster] ?? 0;
        x = centerX + randomBetween(random, -0.42, 0.42);
        y = randomBetween(random, 0.12, 2.8);
        z = centerZ + randomBetween(random, -0.42, 0.42);
        mixed.copy(human).lerp(machine, random() * 0.48);
      } else {
        x = randomBetween(random, -4.2, 4.2);
        y = randomBetween(random, 2.45, 3.65);
        z = randomBetween(random, -7.4, 7.6);
        mixed.copy(field).lerp(violet, random() * 0.52);
      }

      positions[offset] = x;
      positions[offset + 1] = y;
      positions[offset + 2] = z;
      colors[offset] = mixed.r;
      colors[offset + 1] = mixed.g;
      colors[offset + 2] = mixed.b;
    }

    const geometry = new BufferGeometry();
    geometry.setAttribute("position", new BufferAttribute(positions, 3));
    geometry.setAttribute("color", new BufferAttribute(colors, 3));
    geometry.computeBoundingSphere();

    return new Points(
      geometry,
      new PointsMaterial({
        depthWrite: false,
        opacity: 0.9,
        size: 0.078,
        sizeAttenuation: true,
        transparent: true,
        vertexColors: true,
      })
    );
  }

  function createWall(x: number, rotationY: number) {
    const wall = new Mesh(
      new PlaneGeometry(18, 3.8),
      new MeshBasicMaterial({
        color: 0x12313a,
        opacity: 0.28,
        side: DoubleSide,
        transparent: true,
      })
    );
    wall.position.set(x, 1.76, 0);
    wall.rotation.y = rotationY;
    return wall;
  }

  function createKeyLight() {
    const light = new DirectionalLight(0xffffff, 1.45);
    light.position.set(-2.5, 7.2, 5.4);
    return light;
  }

  function createPathLine(pathPoints: Vector3[]) {
    const sampledPoints = Array.from({ length: 90 }, (_, index) =>
      samplePath(pathPoints, index / 89, new Vector3())
    );
    const geometry = new BufferGeometry().setFromPoints(sampledPoints);

    return new Line(
      geometry,
      new LineBasicMaterial({
        color: 0xffb24d,
        opacity: 0.88,
        transparent: true,
      })
    );
  }

  function createScanPlane() {
    const scan = new Mesh(
      new PlaneGeometry(10.6, 0.08),
      new MeshBasicMaterial({
        color: 0x33f0d1,
        opacity: 0.42,
        side: DoubleSide,
        transparent: true,
      })
    );
    scan.rotation.x = -Math.PI / 2;
    scan.position.y = 0.035;
    return scan;
  }

  function createRobot() {
    const robot = new Group();
    const base = new Mesh(
      new CylinderGeometry(0.42, 0.48, 0.18, 36),
      new MeshStandardMaterial({
        color: 0x263540,
        metalness: 0.42,
        roughness: 0.34,
      })
    );
    const body = new Mesh(
      new BoxGeometry(0.62, 0.52, 0.78),
      new MeshStandardMaterial({
        color: 0xb7c8ce,
        emissive: 0x0a1719,
        metalness: 0.22,
        roughness: 0.45,
      })
    );
    const lens = new Mesh(
      new SphereGeometry(0.13, 24, 16),
      new MeshStandardMaterial({
        color: 0x33f0d1,
        emissive: 0x33f0d1,
        emissiveIntensity: 1.2,
        roughness: 0.3,
      })
    );

    base.position.y = 0.12;
    body.position.y = 0.48;
    lens.position.set(0, 0.58, 0.42);
    robot.add(base, body, lens);
    return robot;
  }

  function createAnchor(color: number, label: string) {
    const group = new Group();
    const ring = new Mesh(
      new RingGeometry(0.3, 0.38, 48),
      new MeshBasicMaterial({
        color,
        opacity: 0.78,
        side: DoubleSide,
        transparent: true,
      })
    );
    const hitTarget = new Mesh(
      new SphereGeometry(0.22, 24, 16),
      new MeshStandardMaterial({
        color,
        emissive: color,
        emissiveIntensity: 0.78,
        roughness: 0.38,
      })
    );
    const stem = new Mesh(
      new CylinderGeometry(0.012, 0.012, 0.92, 10),
      new MeshBasicMaterial({
        color,
        opacity: 0.58,
        transparent: true,
      })
    );

    ring.rotation.x = -Math.PI / 2;
    ring.position.y = -0.46;
    stem.position.y = -0.24;
    hitTarget.userData = { isHitTarget: true, label };
    group.add(ring, stem, hitTarget);
    return group;
  }

  function animateWorld(
    world: ReturnType<typeof createWorldScene>,
    elapsed: number,
    reducedMotion: boolean
  ) {
    if (reducedMotion) {
      return;
    }

    const loop = (elapsed * 0.056) % 2;
    const pathProgress = Math.min(loop > 1 ? 2 - loop : loop, 0.999);
    const nextProgress =
      pathProgress > 0.981 ? pathProgress - 0.018 : pathProgress + 0.018;
    samplePath(world.pathPoints, pathProgress, world.robot.position);
    samplePath(world.pathPoints, nextProgress, world.pathLookTarget);
    world.robot.lookAt(
      world.pathLookTarget.x,
      world.robot.position.y,
      world.pathLookTarget.z
    );
    world.scan.position.z = -8.4 + ((elapsed * 1.9) % 16.8);
    world.scan.material.opacity = 0.24 + Math.sin(elapsed * 2.8) * 0.12;
  }

  function hasDisposableGeometry(
    object: Object3D
  ): object is Object3D & { geometry: BufferGeometry } {
    return "geometry" in object;
  }

  function samplePath(points: Vector3[], progress: number, target: Vector3) {
    const clampedProgress = clamp(progress, 0, 0.999);
    const scaledProgress = clampedProgress * (points.length - 1);
    const index = Math.min(points.length - 2, Math.floor(scaledProgress));
    const localProgress = scaledProgress - index;
    return target.copy(points[index]).lerp(points[index + 1], localProgress);
  }

  function hasDisposableMaterial(
    object: Object3D
  ): object is Object3D & {
    material: Material | Material[];
  } {
    return "material" in object;
  }

  function createDeterministicRandom(seed: number) {
    let state = seed;

    return () => {
      state += 0x6d2b79f5;
      let value = state;
      value = Math.imul(value ^ (value >>> 15), value | 1);
      value ^= value + Math.imul(value ^ (value >>> 7), value | 61);
      return ((value ^ (value >>> 14)) >>> 0) / 4294967296;
    };
  }

  function randomBetween(
    random: ReturnType<typeof createDeterministicRandom>,
    min: number,
    max: number
  ) {
    return min + (max - min) * random();
  }

  function easeInOutCubic(value: number) {
    return value < 0.5
      ? 4 * value * value * value
      : 1 - (-2 * value + 2) ** 3 / 2;
  }

  function clamp(value: number, min: number, max: number) {
    return Math.min(Math.max(value, min), max);
  }
</script>
