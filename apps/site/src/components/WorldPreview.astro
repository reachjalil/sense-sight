---
interface Badge {
  label: string;
  value: string;
}

interface Props {
  alt?: string;
  caption?: string;
  image?: string;
  kicker?: string;
  title?: string;
  badges?: Badge[];
}

const {
  image = "/visuals/robot-world-generation.png",
  alt = "Generated product explainer showing robot sensor frames becoming a point-cloud world model, semantic hazards, route overlays, and operator-ready world artifacts.",
  kicker = "Robot stream to world model",
  title = "Capture, reconstruct, review, remember",
  caption = "A product view of the full SenseSight loop: capture, reconstruction, operator review, and durable spatial memory.",
  badges = [
    { label: "Input", value: "RGB-D + pose" },
    { label: "Model", value: "3DGS-ready" },
    { label: "Review", value: "Human loop" },
  ],
} = Astro.props;
---

<figure class="ss-world-preview" aria-label={title}>
  <div class="ss-world-preview__viewport">
    <img src={image} alt={alt} loading="lazy" decoding="async" />
    <div class="ss-world-preview__hud ss-world-preview__hud--top">
      <span><i class="ss-dot"></i>{kicker}</span>
      <span>SenseSight product system</span>
    </div>
    <div class="ss-world-preview__hud ss-world-preview__hud--bottom">
      {
        badges.map((badge) => (
          <span>
            <strong>{badge.label}</strong>
            {badge.value}
          </span>
        ))
      }
    </div>
    <div class="ss-world-preview__scan" aria-hidden="true"></div>
  </div>
  <figcaption class="ss-world-preview__caption">{caption}</figcaption>
</figure>
